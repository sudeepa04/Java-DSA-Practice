int n=sc.nextInt();
int arr[]=new int[n];
for(int i=0;i<n-1;i++){
  int minIndex=i;
  for(int j=i+1;j<n;j++){
    if(arr[j]<arr[minIndex]){
      minIndex=j;
    }
}
//swap
int temp=arr[i];
arr[i]=arr[minIndex];
arr[minIndex]=temp;
}
for(int i=0;i<=n;i++){
  System.out.println("SORTED ARRAY="+arr[i]);
}
}
