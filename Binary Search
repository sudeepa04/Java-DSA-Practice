int n=sc.nextInt();
int[] arr=new int[n];
for(int i=0;i<n;i++){
  arr[i]=sc.nextInt();
}
int key=sc.nextInt();
int high=n-1;
int low=0;
boolean found=false;
while(low<=high){
int mid=(low+high)/2;
if(arr[mid]==key){
System.out.println("found");
found=true;
break;
}
else if(arr[mid]<key){
low=mid+1;
}else{
high=mid-1;
}
}
if(!found){
System.out.println("not found");
}
}
